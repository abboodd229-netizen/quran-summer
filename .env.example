# ===== بيئة التشغيل =====
NODE_ENV=production
PORT=8080

# ===== الأمان =====
# سرّ توقيع/تشفير الجلسات — استبدله بقيمة عشوائية طويلة في الإنتاج
SESSION_SECRET=change-me-to-a-long-random-string

# مدة صلاحية الجلسة (بالأيام)
SESSION_TTL_DAYS=7

# ===== قاعدة البيانات =====
# مسار ملف SQLite (يجب أن يكون داخل قرص دائم/Volume على Railway)
DATABASE_PATH=./data/app.sqlite

# ===== حساب المدير الأولي (يُنشأ عند التهيئة) =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=مدير النظام

# ===== النسخ الاحتياطي =====
# تشغيل النسخ اليومي التلقائي (true/false) وعدد النسخ المحفوظة
BACKUP_ENABLED=true
BACKUP_KEEP=14
